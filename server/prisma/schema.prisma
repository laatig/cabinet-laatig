generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  CLIENT
  OWNER
}

model User {
  id                String           @id @default(cuid())
  email             String           @unique
  passwordHash      String
  fullName          String
  role              UserRole         @default(CLIENT)
  title             String?
  firmName          String?
  phoneNumber       String?
  emailVerified     Boolean          @default(false)
  verificationToken String?
  resetToken        String?
  resetTokenExpiry  DateTime?
  // Company info for client self-registration
  raisonSociale     String?
  clientICE         String?
  clientRC          String?
  formeJuridique    String?
  createdAt         DateTime         @default(now())
  updatedAt         DateTime         @updatedAt
  projects          Project[]
  auditLogs         AuditLog[]
  notifications     Notification[]
  signatures        Signature[]
  clientCompany     ClientCompany?
}

model ClientCompany {
  id              String    @id @default(cuid())
  userId          String
  user            User      @relation(fields: [userId], references: [id])
  raisonSociale   String
  clientICE       String    @unique
  clientRC        String?
  formeJuridique  String?
  adresse         String?
  ville           String?
  telephone       String?
  email           String?
  fiscalYearEnd   DateTime?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  projects        Project[]
}

model Project {
  id              String         @id @default(cuid())
  userId          String
  user            User           @relation(fields: [userId], references: [id])
  companyId       String?
  company         ClientCompany? @relation(fields: [companyId], references: [id])
  clientName      String
  clientAddress   String?
  clientICE       String?
  clientRC        String?
  clientTP        String?
  fiscalYearStart DateTime
  fiscalYearEnd   DateTime
  auditType       String
  status          ProjectStatus  @default(IN_PROGRESS)
  dossierStatus   DossierStatus  @default(DOCUMENTS_RECEIVED)
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt
  documents       Document[]
  transactions    Transaction[]
  anomalies       Anomaly[]
  journalEntries  JournalEntry[]
  reports         Report[]
  notifications   Notification[]
  auditLogs       AuditLog[]
  signatures      Signature[]
}

enum ProjectStatus {
  IN_PROGRESS
  REVIEW
  COMPLETED
}

enum DossierStatus {
  DOCUMENTS_RECEIVED
  EXTRACTION_IN_PROGRESS
  AI_ANALYSIS
  IN_REVIEW
  AWAITING_CLIENT_CORRECTION
  VALIDATED
  SIGNED
}

enum FinancialDocumentCategory {
  BILAN
  CPC
  BALANCE
  ESG
  TABLEAU_FINANCEMENT
  ETIC
  PIECE_JUSTIFICATIVE
}

model Document {
  id                String                    @id @default(cuid())
  projectId         String
  project           Project                   @relation(fields: [projectId], references: [id])
  fileName          String
  fileType          String
  filePath          String
  pageCount         Int                       @default(0)
  category          FinancialDocumentCategory @default(PIECE_JUSTIFICATIVE)
  fiscalYear        Int?
  version           Int                       @default(1)
  originalDocId     String?
  status            DocumentStatus            @default(UPLOADED)
  createdAt         DateTime                  @default(now())
  updatedAt         DateTime                  @updatedAt
  transactions      Transaction[]
  extractions       Extraction[]
}

enum DocumentStatus {
  UPLOADED
  PROCESSING
  EXTRACTED
  AWAITING_REVIEW
  REVIEWED
  FAILED
}

model Transaction {
  id             String            @id @default(cuid())
  projectId      String
  project        Project           @relation(fields: [projectId], references: [id])
  documentId     String?
  document       Document?         @relation(fields: [documentId], references: [id])
  pcmAccountId   String?
  pcmAccount     PcmAccount?       @relation(fields: [pcmAccountId], references: [id])
  documentType   DocumentType
  vendorName     String?
  documentNumber String?
  date           DateTime?
  dueDate        DateTime?
  totalAmount    Decimal           @db.Decimal(15, 2)
  currency       String            @default("MAD")
  taxAmount      Decimal?          @db.Decimal(15, 2)
  taxRate        Decimal?          @db.Decimal(5, 2)
  description    String?
  category       String?
  riskScore      Int               @default(0)
  status         TransactionStatus @default(EXTRACTED)
  isDuplicate    Boolean           @default(false)
  duplicateOfId  String?
  notes          String?
  createdAt      DateTime          @default(now())
  lineItems      LineItem[]
  anomalies      Anomaly[]
  journalEntries JournalEntry[]
}

enum DocumentType {
  INVOICE
  RECEIPT
  BANK_STATEMENT
}

enum TransactionStatus {
  EXTRACTED
  VERIFIED
  FLAGGED
  DISPUTED
}

model LineItem {
  id            String      @id @default(cuid())
  transactionId String
  transaction   Transaction @relation(fields: [transactionId], references: [id])
  description   String
  quantity      Decimal     @db.Decimal(10, 3)
  unitPrice     Decimal     @db.Decimal(15, 2)
  amount        Decimal     @db.Decimal(15, 2)
}

model Anomaly {
  id            String        @id @default(cuid())
  transactionId String
  transaction   Transaction   @relation(fields: [transactionId], references: [id])
  projectId     String
  project       Project       @relation(fields: [projectId], references: [id])
  type          String
  severity      Severity
  description   String
  explanation   String?
  status        AnomalyStatus @default(OPEN)
  createdAt     DateTime      @default(now())
}

enum Severity {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

enum AnomalyStatus {
  OPEN
  ACCEPTED
  REJECTED
}

model PcmAccount {
  id             String         @id @default(cuid())
  accountNumber  String         @unique
  accountName    String
  classNumber    Int
  className      String
  isActive       Boolean        @default(true)
  transactions   Transaction[]
  journalEntries JournalEntry[]
}

model JournalEntry {
  id            String       @id @default(cuid())
  projectId     String
  project       Project      @relation(fields: [projectId], references: [id])
  transactionId String?
  transaction   Transaction? @relation(fields: [transactionId], references: [id])
  date          DateTime
  accountNumber String
  pcmAccountId  String?
  pcmAccount    PcmAccount?  @relation(fields: [pcmAccountId], references: [id])
  description   String
  debit         Decimal      @db.Decimal(15, 2) @default(0)
  credit        Decimal      @db.Decimal(15, 2) @default(0)
  reference     String?
}

model Report {
  id          String     @id @default(cuid())
  projectId   String
  project     Project    @relation(fields: [projectId], references: [id])
  reportType  ReportType
  filePath    String
  generatedAt DateTime   @default(now())
}

enum ReportType {
  BILAN
  CPC
  JOURNAL
  GRAND_LIVRE
  BALANCE
  TVA
  AUDIT
  SYNTHESE
  CAHIER_TRAVAIL
}

model Extraction {
  id             String             @id @default(cuid())
  documentId     String
  document       Document           @relation(fields: [documentId], references: [id])
  status         ExtractionStatus   @default(PENDING)
  confidence     Decimal            @db.Decimal(5, 2)
  modelUsed      String
  processedAt    DateTime           @default(now())
  reviewedAt     DateTime?
  reviewedBy     String?
  reviewerNotes  String?
  fields         ExtractionField[]
}

enum ExtractionStatus {
  PENDING
  PROCESSING
  COMPLETED
  FAILED
  REVIEWED
}

model ExtractionField {
  id              String     @id @default(cuid())
  extractionId    String
  extraction      Extraction @relation(fields: [extractionId], references: [id])
  fieldName       String
  fieldValue      String
  fieldType       String     @default("text")
  confidence      Decimal    @db.Decimal(5, 2)
  originalValue   String?
  correctedValue  String?
  isCorrected     Boolean    @default(false)
  section         String?
  createdAt       DateTime   @default(now())
}

model Signature {
  id              String   @id @default(cuid())
  userId          String
  user            User     @relation(fields: [userId], references: [id])
  projectId       String
  project         Project  @relation(fields: [projectId], references: [id])
  signatureData   String
  signatureType   String   @default("drawn")
  fullName        String
  title           String
  ipAddress       String?
  signedAt        DateTime @default(now())
}

model Notification {
  id        String           @id @default(cuid())
  projectId String
  project   Project          @relation(fields: [projectId], references: [id])
  userId    String?
  user      User?            @relation(fields: [userId], references: [id])
  type      NotificationType
  message   String
  isRead    Boolean          @default(false)
  createdAt DateTime         @default(now())
}

enum NotificationType {
  STATUS_CHANGE
  ANOMALY_DETECTED
  REPORT_READY
  REVIEW_COMPLETE
  EXTRACTION_COMPLETE
  DOCUMENT_UPLOADED
  SIGNATURE_REQUEST
  DOCUMENT_REJECTED
}

model AuditLog {
  id        String   @id @default(cuid())
  userId    String?
  user      User?    @relation(fields: [userId], references: [id])
  projectId String?
  project   Project? @relation(fields: [projectId], references: [id])
  action    String
  details   Json?
  ipAddress String?
  timestamp DateTime @default(now())
}
